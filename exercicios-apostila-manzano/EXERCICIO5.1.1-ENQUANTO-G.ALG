Algoritmo "exercicio5.1.1-enquanto-G"
// Aula        : Lógica de programaçăo com Visual G
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Escreva um programa que apresente a série de Fibonacci
// até o décimo quinto termo. A série de Fibonacci é formada pela
// seqüęncia: 1, 1, 2, 3, 5, 8, 13, 21, 34, ..., etc. Esta série se
// caracteriza pela soma de um termo atual com o seu anterior subseqüente,
// para que seja formado o próximo valor da seqüęncia. Portanto
// começando com os números 1, 1 o próximo termo é 1+1=2, o próximo
// é 1+2=3, o próximo é 2+3=5, o próximo 3+5=8, etc.
// Autor(a)    : Renan de Castro Teixeira
// Data atual  : 05/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   anterior, atual, soma, contadora: inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Mostra a sequencia de Fibonacci até o 15ş termo.")

   contadora <- 3
   anterior <- 1
   atual <- 1
   
   escreval(anterior)
   escreval(atual)
   
   enquanto contadora <= 15 faca
      soma <- anterior + atual
      anterior <- atual
      atual <- soma
      escreval(soma)
      contadora <- contadora + 1
   fimenquanto

Fimalgoritmo